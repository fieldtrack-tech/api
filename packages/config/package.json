{
  "name": "@fieldtrack/config",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Shared environment contract types and validators for FieldTrack 2.0.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepare": "node -e \"if(require('fs').existsSync('src')){require('child_process').execSync('npm run build',{stdio:'inherit',shell:true})}\""
  },
  "dependencies": {
    "zod": "^3.25.23"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
