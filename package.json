{
  "name": "fieldtrack",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace packages/types && npm run build --workspace packages/config && npm run build --workspace apps/api",
    "dev": "npm --workspace apps/api run dev",
    "dev:api": "npm --workspace apps/api run dev",
    "start": "npm --workspace apps/api run start",
    "typecheck": "tsc -b apps/api --pretty",
    "test": "npm run test --workspace apps/api"
  }
}
